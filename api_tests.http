#############################################
# Polls
#############################################

### List Polls
GET {{baseUrl}}/api/v1/communications/polls/
Authorization: Bearer {{accessToken}}

### Get Poll by ID
GET {{baseUrl}}/api/v1/communications/polls/1/
Authorization: Bearer {{accessToken}}

### Create Poll
POST {{baseUrl}}/api/v1/communications/polls/
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "question": "Где провести корпоратив?",
  "options": [
    {"text": "Ресторан"},
    {"text": "Боулинг"},
    {"text": "Квест-комната"}
  ],
  "multiple_choice": false,
  "anonymous": false
}

### Vote in Poll
POST {{baseUrl}}/api/v1/communications/polls/1/vote/
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "option_id": 1
}
