  (function(){
    const m = document.getElementById('groupsPickerModal');
    if (m && m.parentNode !== document.body) {
      document.body.appendChild(m);
    }
  })();
</script>

<script>
(function(){
  'use strict';

  const wrap = document.getElementById('empGroupsBlock');
  if (!wrap) return;

  const bulkUrl   = wrap.dataset.bulkUrl || '';    // /employees/<id>/groups/bulk/
  const createUrl = wrap.dataset.createUrl || '';  // /groups/create/
  const deleteUrl = wrap.dataset.deleteUrl || '';  // /groups/delete/
  const csrftoken = document.querySelector('#apiEditForm input[name=csrfmiddlewaretoken]')?.value || '';

  const hidden    = document.getElementById('emp_groups_hidden');
  const listBox   = document.getElementById('empGroupsList');
  const search    = document.getElementById('empGroupsSearch');
  const clearBtn  = document.getElementById('empGroupsClear');
  const doneBtn   = document.getElementById('empGroupsDone');
  const msgBox    = document.getElementById('empGroupsMsg');

  const assignBtn = document.getElementById('empGroupsAssignBtn');
  const removeBtn = document.getElementById('empGroupsRemoveBtn');

  const createName = document.getElementById('empGroupsCreateName');
  const createBtn  = document.getElementById('empGroupsCreateBtn');
  const createMsg  = document.getElementById('empGroupsCreateMsg');

  const delSel   = document.getElementById('empGroupsDeleteSelect');
  const delBtn   = document.getElementById('empGroupsDeleteBtn');
  const delMsg   = document.getElementById('empGroupsDeleteMsg');

  const assignedBox = document.getElementById('empGroupsAssigned');

  // --- переносим модал в body и предзаполняем чекбоксы текущими группами ---
  (function(){
    const m = document.getElementById('empGroupsPickerModal');
    if (m && m.parentNode !== document.body) document.body.appendChild(m);

    // При открытии модала отметим чекбоксы, соответствующие уже назначенным группам
    m?.addEventListener('show.bs.modal', () => {
      const assigned = new Set(
        Array.from(assignedBox?.querySelectorAll('[data-gid]') || [])
          .map(x => x.dataset.gid)
          .filter(Boolean)
      );
      const ids = [];
      listBox?.querySelectorAll('.emp-group-check').forEach(ch => {
        const on = assigned.has(ch.value);
        ch.checked = on;
        if (on) ids.push(ch.value);
      });
      if (hidden) hidden.value = ids.join(',');
    });
  })();

  // --- helpers ---
  function busy(btn, on){
    if (!btn) return;
    const lbl = btn.querySelector('.lbl');
    const sp  = btn.querySelector('.spinner-border');
    if (on){ btn.setAttribute('disabled',''); sp?.classList.remove('d-none'); lbl?.classList.add('visually-hidden'); }
    else    { btn.removeAttribute('disabled');  sp?.classList.add('d-none');   lbl?.classList.remove('visually-hidden'); }
  }

  function showMsg(el, text, ok){
    if (!el) return;
    el.textContent = text || '';
    el.classList.toggle('d-none', !text);
    el.classList.toggle('text-success', !!ok);
    el.classList.toggle('text-danger', !ok);
  }

  function selectedIds(){
    if (!hidden) return [];
    const csv = (hidden.value || '').trim();
    return csv ? csv.split(',').map(s => s.trim()).filter(Boolean) : [];
  }

  function setSelected(ids){
    if (hidden) hidden.value = (ids || []).join(',');
  }

  function ensureEmptyStub(){
    if (!assignedBox) return;
    if (!assignedBox.children.length){
      const span = document.createElement('span');
      span.className = 'text-secondary small';
      span.textContent = 'Нет персональных групп';
      assignedBox.appendChild(span);
    }
  }

  function clearEmptyStub(){
    const stub = assignedBox?.querySelector('.text-secondary.small');
    if (stub) stub.remove();
  }

  function namesDict(){
    const m = {};
    listBox?.querySelectorAll('.emp-group-check').forEach(ch => {
      const nm = ch.closest('.list-group-item')?.querySelector('.flex-grow-1')?.textContent || ('#'+ch.value);
      m[ch.value] = nm;
    });
    return m;
  }

  function addAssignedPills(ids){
    if (!assignedBox || !ids?.length) return;
    clearEmptyStub();
    const map = namesDict();
    ids.forEach(id => {
      const key = String(id);
      if (assignedBox.querySelector(`[data-gid="${key}"]`)) return;
      const pill = document.createElement('span');
      pill.className = 'badge rounded-pill bg-primary-subtle text-primary-emphasis border';
      pill.dataset.gid = key;
      pill.textContent = map[key] || ('#' + key);
      assignedBox.appendChild(pill);
    });
    ensureEmptyStub();
  }

  function removeAssignedPills(ids){
    if (!assignedBox || !ids?.length) return;
    ids.forEach(id => assignedBox.querySelector(`[data-gid="${String(id)}"]`)?.remove());
    ensureEmptyStub();
  }

  // --- список/поиск/сохранение выбранных в модалке ---
  listBox?.addEventListener('change', (e) => {
    const ch = e.target.closest('.emp-group-check');
    if (!ch) return;
    const ids = new Set(selectedIds());
    if (ch.checked) ids.add(ch.value); else ids.delete(ch.value);
    setSelected(Array.from(ids));
  });

  search?.addEventListener('input', () => {
    if (!listBox) return;
    const q = (search.value || '').toLowerCase().trim();
    listBox.querySelectorAll('.list-group-item').forEach(row => {
      const name = row.querySelector('.flex-grow-1')?.textContent.toLowerCase() || '';
      const id   = row.querySelector('.emp-group-check')?.value || '';
      row.classList.toggle('d-none', !(name.includes(q) || id.includes(q)));
    });
  });

  clearBtn?.addEventListener('click', () => {
    setSelected([]);
    listBox?.querySelectorAll('.emp-group-check').forEach(ch => ch.checked = false);
  });

  doneBtn?.addEventListener('click', () => {
    // выбор уже сохранён в hidden по change
  });

  // --- сетевой helper ---
  async function postJSON(url, body){
    const resp = await fetch(url, {
      method: 'POST',
      headers: {
        'Content-Type':'application/json',
        'Accept':'application/json',
        'X-Requested-With':'XMLHttpRequest',
        'X-CSRFToken': csrftoken
      },
      credentials: 'same-origin',
      body: JSON.stringify(body || {})
    });
    let data = null;
    try { data = await resp.json(); } catch {}
    if (!resp.ok){
      const detail = (data && (data.detail || data.error)) || resp.statusText || ('HTTP ' + resp.status);
      throw new Error(detail);
    }
    return data || {};
  }

  // --- bulk add/remove с обновлением «пилюль» ---
  async function bulkMembership(action){
    const ids = selectedIds().map(id => Number(id)).filter(n => !Number.isNaN(n));
    if (!ids.length){ showMsg(msgBox, 'Не выбраны группы.', false); return; }
    if (!bulkUrl){ showMsg(msgBox, 'Не настроен endpoint bulkUrl.', false); return; }
    const btn = (action === 'add') ? assignBtn : removeBtn;
    busy(btn, true); showMsg(msgBox, '', true);
    try{
      const data = await postJSON(bulkUrl, { action, group_ids: ids });

      // считаем реально успешные id (без требования ok_ids от API)
      const failedMap = data.failed || {};
      const successIds = ids.filter(id => !(String(id) in failedMap));

      if (action === 'add') addAssignedPills(successIds);
      else removeAssignedPills(successIds);

      // синхронизируем чекбоксы и hidden сразу, чтоб при повторном открытии модалки всё было актуально
      const selSet = new Set(selectedIds()); // строковые значения
      successIds.forEach(id => {
        const val = String(id);
        const ch = listBox?.querySelector(`.emp-group-check[value="${val}"]`);
        if (action === 'add'){
          ch && (ch.checked = true);
          selSet.add(val);
        } else {
          ch && (ch.checked = false);
          selSet.delete(val);
        }
      });
      setSelected(Array.from(selSet));

      const failed = Object.keys(failedMap).length;
      const ok = successIds.length;
      showMsg(msgBox, failed ? `Успех: ${ok}, ошибок: ${failed}.` : `Готово: ${ok} групп обработано.`, !failed);
    }catch(e){
      showMsg(msgBox, 'Ошибка: ' + String(e.message || e), false);
    }finally{
      busy(btn, false);
    }
  }

  assignBtn?.addEventListener('click', () => bulkMembership('add'));
  removeBtn?.addEventListener('click', () => bulkMembership('remove'));

  // --- Создание группы (через /groups/create/) ---
  createBtn?.addEventListener('click', async () => {
    const name = (createName.value || '').trim();
    if (!name){ showMsg(createMsg, 'Укажите имя группы (CN).', false); return; }
    if (!createUrl){ showMsg(createMsg, 'Не настроен endpoint createUrl.', false); return; }
    busy(createBtn, true); showMsg(createMsg, '', true);
    try{
      const data = await postJSON(createUrl, { name });

      // добавить в список в модалке
      const row = document.createElement('label');
      row.className = 'list-group-item d-flex align-items-center gap-2';
      row.innerHTML = `
        <input class="form-check-input me-2 emp-group-check" type="checkbox" value="${data.id}" data-cn="${data.name}">
        <span class="flex-grow-1">${data.name}</span>
        <span class="text-secondary small">#${data.id}</span>`;
      listBox?.appendChild(row);

      // добавить в select удаления
      const opt = document.createElement('option');
      opt.value = String(data.id); opt.textContent = data.name;
      delSel?.appendChild(opt);

      showMsg(createMsg, 'Группа создана.', true);
      createName.value = '';
    }catch(e){
      showMsg(createMsg, 'Не удалось создать: ' + String(e.message || e), false);
    }finally{
      busy(createBtn, false);
    }
  });

  // --- Удаление группы (через /groups/delete/) ---
  delBtn?.addEventListener('click', async () => {
    const gid = Number(delSel?.value || 0);
    if (!gid){ showMsg(delMsg, 'Выберите группу.', false); return; }
    if (!deleteUrl){ showMsg(delMsg, 'Не настроен endpoint deleteUrl.', false); return; }
    if (!confirm('Удалить группу? Действие необратимо.')) return;
    busy(delBtn, true); showMsg(delMsg, '', true);
    try{
      await postJSON(deleteUrl, { group_id: gid });

      // убрать из UI
      listBox?.querySelector(`.emp-group-check[value="${gid}"]`)?.closest('.list-group-item')?.remove();
      delSel?.querySelector(`option[value="${gid}"]`)?.remove();

      // убрать из выбранных
      const ids = new Set(selectedIds());
      ids.delete(String(gid));
      setSelected(Array.from(ids));

      // убрать «пилюлю», если была назначена
      removeAssignedPills([gid]);

      showMsg(delMsg, 'Группа удалена.', true);
    }catch(e){
      showMsg(delMsg, 'Не удалось удалить: ' + String(e.message || e), false);
    }finally{
      busy(delBtn, false);
    }
  });

  // при загрузке гарантируем плейсхолдер «Нет персональных групп», если нужно
  ensureEmptyStub();
})();
</script>
<script>
(function(){
  const form  = document.getElementById('apiEditForm');
  const block = document.getElementById('positionBlock');
  const select = document.getElementById('f_position');
  if (!form || !block || !select) return;

  const csrftoken = form.querySelector('input[name=csrfmiddlewaretoken]')?.value || '';
  const updateTpl = block.dataset.updateUrlTpl || '';
  const detailTpl = block.dataset.detailUrlTpl || '';   // ← фронтовая detail-вьюха
  const canAssign = block.dataset.canAssign === '1';

  const nameInp   = document.getElementById('pos_edit_name');
  const descInp   = document.getElementById('pos_edit_desc');
  const chipsBox  = document.getElementById('pos_edit_groups_chips');
  const hidden    = document.getElementById('pos_edit_groups_hidden');
  const msgBox    = document.getElementById('posEditMsg');
  const loadBtn   = document.getElementById('posEditLoadBtn');
  const saveBtn   = document.getElementById('posEditSaveBtn');

  const modalEl   = document.getElementById('posEditGroupsPickerModal');
  const listBox   = document.getElementById('posEditGroupsList');
  const search    = document.getElementById('posEditGroupsSearch');
  const clearBtn  = document.getElementById('posEditGroupsClear');
  const doneBtn   = document.getElementById('posEditGroupsDone');
  const clearGroupsBtn = document.getElementById('posEditClearGroups');

  if (modalEl && modalEl.parentNode !== document.body) document.body.appendChild(modalEl);

  function busy(btn, on){
    if (!btn) return;
    const lbl = btn.querySelector('.lbl');
    const sp  = btn.querySelector('.spinner-border');
    if (on){ btn.setAttribute('disabled',''); sp?.classList.remove('d-none'); lbl?.classList.add('visually-hidden'); }
    else    { btn.removeAttribute('disabled');  sp?.classList.add('d-none');   lbl?.classList.remove('visually-hidden'); }
  }
  function showMsg(text, ok){
    msgBox.textContent = text || '';
    msgBox.classList.toggle('d-none', !text);
    msgBox.classList.toggle('text-success', !!ok);
    msgBox.classList.toggle('text-danger', !ok);
  }

  function currentIds(){ const v=(hidden?.value||'').trim(); return v? v.split(',').map(s=>s.trim()).filter(Boolean):[]; }
  function setIds(ids){ if (hidden) hidden.value=(ids||[]).join(','); renderChips(); syncChecksFromHidden(); }
  function renderChips(){
    if (!chipsBox) return;
    chipsBox.innerHTML = '';
    const ids = currentIds(); if (!ids.length) return;
    const nameById = {};
    listBox?.querySelectorAll('.pos-edit-group-check').forEach(ch=>{
      const nm = ch.closest('.list-group-item')?.querySelector('.flex-grow-1')?.textContent || ('#'+ch.value);
      nameById[ch.value] = nm;
    });
    ids.forEach(id=>{
      const chip = document.createElement('span');
      chip.className = 'chip';
      chip.dataset.id = id;
      chip.innerHTML = `${nameById[id] || ('#'+id)} <button type="button" class="btn btn-sm p-0 ms-1" aria-label="Удалить" style="line-height:1;">×</button>`;
      chipsBox.appendChild(chip);
    });
  }
  chipsBox?.addEventListener('click', (e)=>{
    const btn = e.target.closest('button'); const chip = btn?.closest('.chip'); if (!chip) return;
    const ids = new Set(currentIds()); ids.delete(chip.dataset.id); setIds(Array.from(ids));
  });
  function syncChecksFromHidden(){
    const ids = new Set(currentIds());
    listBox?.querySelectorAll('.pos-edit-group-check').forEach(ch=> ch.checked = ids.has(ch.value));
  }
  function syncHiddenFromChecks(){
    const ids=[]; listBox?.querySelectorAll('.pos-edit-group-check:checked').forEach(ch=>ids.push(ch.value));
    setIds(ids);
  }

  search?.addEventListener('input', ()=>{
    const q=(search.value||'').toLowerCase().trim();
    listBox?.querySelectorAll('.list-group-item').forEach(row=>{
      const name=row.querySelector('.flex-grow-1')?.textContent.toLowerCase()||'';
      const id=row.querySelector('.pos-edit-group-check')?.value||'';
      row.classList.toggle('d-none', !(name.includes(q)||id.includes(q)));
    });
  });
  clearBtn?.addEventListener('click', ()=>{ listBox?.querySelectorAll('.pos-edit-group-check').forEach(ch=>ch.checked=false); setIds([]); });
  doneBtn?.addEventListener('click', syncHiddenFromChecks);
  clearGroupsBtn?.addEventListener('click', ()=> setIds([]));

  function buildUrlFromTpl(tpl, id){
    if (!tpl) return '';
    if (tpl.includes('/0/')) return tpl.replace('/0/', `/${id}/`);
    if (tpl.endsWith('0')) return tpl.slice(0,-1) + id;
    return tpl.replace('0', String(id));
  }
  function buildUpdateUrl(posId){ return buildUrlFromTpl(updateTpl, posId); }
  function buildDetailUrl(posId){ return buildUrlFromTpl(detailTpl, posId); } // ← используем фронт-вью

  async function loadPositionDetail(posId){
    if (!posId){ showMsg('Выберите должность в выпадающем списке.', false); return; }
    const url = buildDetailUrl(posId);
    if (!url){ showMsg('Не настроен URL detail-вьюхи должности.', false); return; }

    showMsg('', true); busy(loadBtn, true);
    try{
      const resp = await fetch(url, {
        credentials:'same-origin',
        headers:{ 'Accept':'application/json', 'X-Requested-With':'XMLHttpRequest' }
      });
      const data = await (async()=>{ try{return await resp.json()}catch{return null} })();
      if (!resp.ok){ showMsg(data?.detail || `Не удалось загрузить должность (HTTP ${resp.status})`, false); return; }

      nameInp && (nameInp.value = data?.name || '');
      descInp && (descInp.value = data?.description || '');

      if (canAssign){
        const groupsRaw = Array.isArray(data?.groups) ? data.groups
                       : Array.isArray(data?.groups_ids) ? data.groups_ids : [];
        const ids = groupsRaw.map(x => (typeof x==='number' ? String(x) : String(x?.id || x))).filter(Boolean);
        setIds(ids);
      }
      showMsg('Данные должности загружены.', true);
    }catch(_){
      showMsg('Ошибка загрузки должности.', false);
    }finally{
      busy(loadBtn, false);
    }
  }

  async function savePositionChanges(){
    const posId = Number(select.value || 0);
    if (!posId){ showMsg('Сначала выберите должность, которую хотите редактировать.', false); return; }
    const updateUrl = buildUpdateUrl(posId);
    if (!updateUrl){ showMsg('Не настроен URL обновления должности.', false); return; }

    const payload = {};
    const nm = (nameInp?.value || '').trim();
    const ds = (descInp?.value || '').trim();
    if (nm) payload.name = nm;
    payload.description = ds;
    if (canAssign){
      const groups = currentIds().map(x=>Number(x)).filter(n=>!Number.isNaN(n));
      payload.groups = groups;
    }

    showMsg('', true); busy(saveBtn, true);
    try{
      const resp = await fetch(updateUrl, {
        method: 'POST', // фронт-прокси примет POST и внутри пошлёт PATCH
        credentials: 'same-origin',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
          'X-Requested-With':'XMLHttpRequest',
          'X-CSRFToken': csrftoken
        },
        body: JSON.stringify(payload)
      });
      const data = await (async()=>{ try{return await resp.json()}catch{return null} })();
      if (!resp.ok){ showMsg(data?.detail || `Не удалось сохранить (HTTP ${resp.status})`, false); return; }

      if (payload.name){
        const opt = Array.from(select.options).find(o => o.value == String(posId));
        if (opt) opt.textContent = payload.name;
      }

      try{ if (window.bootstrap) new bootstrap.Collapse(document.getElementById('editPositionPane'), {toggle:false}).hide(); }catch(_){}
      showMsg('Изменения сохранены.', true);
    }catch(_){
      showMsg('Ошибка сохранения изменений.', false);
    }finally{
      busy(saveBtn, false);
    }
  }

  document.getElementById('toggleEditPositionBtn')?.addEventListener('click', ()=>{
    const posId = Number(select.value || 0);
    if (posId) setTimeout(()=> loadPositionDetail(posId), 150);
    else showMsg('Выберите должность в выпадающем списке.', false);
  });
  document.getElementById('posEditLoadBtn')?.addEventListener('click', ()=> loadPositionDetail(Number(select.value || 0)));
  document.getElementById('posEditSaveBtn')?.addEventListener('click', savePositionChanges);
})();
</script>
