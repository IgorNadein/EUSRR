# --- Django ---
DJANGO_SECRET_KEY=change-me
DEBUG=True
USE_SQLITE=True
ALLOWED_HOSTS=localhost,127.0.0.1

# If you want to use Postgres instead of SQLite (set USE_SQLITE=False)
POSTGRES_USER=eusrr_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=eusrr
DB_HOST=postgres
DB_PORT=5432

# --- Secondary HikCentral DB (optional; map your own instance) ---
HIK_DB_NAME=cms
HIK_DB_USER=postgres
HIK_DB_PASSWORD=change-me
HIK_DB_HOST=postgres
HIK_DB_PORT=5432

# --- Redis for Channels/WebSockets ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Email (SMTP) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_USE_SSL=true
EMAIL_USE_TLS=false
EMAIL_HOST_USER=no-reply@example.com
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=Robotail <no-reply@example.com>

# --- Regional / API base ---
PHONE_DEFAULT_REGION=RU
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:9000,http://localhost:9000
API_BASE_URL=http://127.0.0.1:9000/api

# --- Integrations (placeholders) ---
TELEGRAM_BOT_TOKEN=put-your-token-here
USERNAME_TELEGRAM_BOT=your_bot_username
SMS_API_TOKEN=...
SMS_API_URL=https://new.smsgorod.ru/apiSms/create/
SMS_API_SENDER=EUSRR
