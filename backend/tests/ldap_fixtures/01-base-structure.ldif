# Базовая структура OU для тестов
dn: ou=Users,dc=test,dc=local
objectClass: organizationalUnit
ou: Users
description: Container for test users

dn: ou=Groups,dc=test,dc=local
objectClass: organizationalUnit
ou: Groups
description: Container for test groups

dn: ou=Departments,dc=test,dc=local
objectClass: organizationalUnit
ou: Departments
description: Container for test departments

# Тестовый пользователь для начальной проверки
dn: cn=test.user,ou=Users,dc=test,dc=local
objectClass: inetOrgPerson
objectClass: posixAccount
objectClass: top
cn: test.user
sn: User
givenName: Test
uid: test.user
uidNumber: 10001
gidNumber: 10001
homeDirectory: /home/test.user
mail: test.user@test.local
userPassword: {SSHA}test123
description: Test user for LDAP integration tests

# Тестовая группа
dn: cn=test-group,ou=Groups,dc=test,dc=local
objectClass: groupOfNames
cn: test-group
description: Test group for integration tests
member: cn=test.user,ou=Users,dc=test,dc=local

# Тестовый отдел
dn: ou=IT,ou=Departments,dc=test,dc=local
objectClass: organizationalUnit
ou: IT
description: IT Department for testing
