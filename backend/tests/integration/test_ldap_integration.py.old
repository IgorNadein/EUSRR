@pytest.mark.django_db
def test_full_user_lifecycle_with_ldap(
    api_client, ldap_test_settings, clean_ldap_users
):
    """INT-4: Полный жизненный цикл пользователя с LDAP"""
    
    # 1. Регистрация
    reg_data = {
        "email": "lifecycle.test@test.local",
        "first_name": "Lifecycle",
        "last_name": "Test",
        "phone_number": "+79990007777",
        "password": "SecurePass123!",
        "whatsapp": "+79990007777",
        "birth_date": "1990-01-01",
    }
    
    reg_response = api_client.post(
        reverse("api:v1:register"),
        reg_data,
        format="json"
    )
    assert reg_response.status_code == status.HTTP_201_CREATED
    
    # 2. Верификация email
    user = Employee.objects.get(email="lifecycle.test@test.local")
    verify_response = api_client.post(
        reverse("api:v1:verify-email"),
        {
            "email": "lifecycle.test@test.local",
            "code": user.email_activation_code,
        },
        format="json"
    )
    assert verify_response.status_code == status.HTTP_200_OK
    
    # 3. Проверяем финальное состояние
    user.refresh_from_db()
    assert user.is_active is True
    assert user.email_verified is True
    
    # TODO: Проверить состояние в LDAP
    # - Пользователь существует
    # - Пользователь активен
    # - Пароль установлен корректно


