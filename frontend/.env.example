# Next.js Environment Variables Example
# Copy this file to .env.local for local development
# Copy this file to .env for production

# Backend API URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:9000

# API URL (optional, defaults to BACKEND_URL/api/v1)
NEXT_PUBLIC_API_URL=http://localhost:9000/api/v1

# WebSocket URL (БЕЗ пути /ws/, он добавляется автоматически в коде)
NEXT_PUBLIC_WS_URL=ws://localhost:9000
