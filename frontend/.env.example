# Next.js environment variables example.
# Copy this file to .env.local for local development and replace placeholders.

# Backend API URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# API URL (optional, defaults to BACKEND_URL/api/v1)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# WebSocket URL without the /ws/ path; the application adds it automatically.
NEXT_PUBLIC_WS_URL=ws://localhost:8000
